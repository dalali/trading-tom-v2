# trading-tom-v2 — environment configuration
# Copy to .env and fill in secrets

# App
APP_ENV=development
DEBUG=true

# Database
POSTGRES_DB=trading_tom_v2
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
DATABASE_URL=postgresql://dev:dev@db:5432/trading_tom_v2

# Auth
JWT_SECRET=dev-secret-change-me

# Admin bootstrap (creates the first admin on first startup if no admin
# exists yet; see architecture 6.3). Safe to leave set for local dev —
# bootstrap is idempotent and never overwrites an existing admin.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=changeme123

# Market data API (optional — only used by the Alpha Vantage fallback
# adapter; yfinance, the primary provider, needs no API key)
# MARKET_DATA_API_KEY=

# Frontend
# Left unset / empty by default: the React app calls relative paths
# (e.g. "/auth/login"), which CRA's dev-server `proxy` field (frontend/
# package.json) forwards to the api service. This keeps the browser on
# a single origin so the HttpOnly refresh cookie stays first-party
# (architecture 8.1's CRA-proxy option). Only set this if serving the
# frontend from somewhere the CRA proxy can't reach the api container.
# REACT_APP_API_BASE=
